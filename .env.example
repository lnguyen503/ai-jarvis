# Jarvis — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Telegram Bot Token — from @BotFather
# Legacy single-bot var. v1.21.0+ also reads BOT_TOKEN_AI_JARVIS (set both
# to the same value if you only run the orchestrator bot).
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Anthropic Claude API Key — https://console.anthropic.com
# Used for the premium fallback model when the local provider errors and for
# vision (image input).
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Ollama Cloud API Key — https://ollama.com/settings/api-keys
# Primary model provider (subscription-based; no per-token cost).
OLLAMA_API_KEY=your-ollama-api-key-here

# OpenAI API Key — https://platform.openai.com
# Optional. Required only for voice-message transcription (Whisper).
OPENAI_API_KEY=your-openai-api-key-here

# Tavily API Key — https://tavily.com
# Optional. Required only for the web_search tool and /search command.
TAVILY_API_KEY=your-tavily-api-key-here

# Google OAuth (Calendar + Gmail) — Desktop-app credentials from
# https://console.cloud.google.com/apis/credentials
# Optional. Required only if you enable google.calendar / google.gmail.
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret

# Optional: override config file path (default: ./config/config.json)
# CONFIG_PATH=./config/config.json

# Optional: log level override (trace|debug|info|warn|error|fatal)
# LOG_LEVEL=info

# Optional: Node environment
NODE_ENV=production

# ---------------------------------------------------------------------------
# Multi-bot ensemble — extra bot tokens (v1.21.0+)
# Each bot needs its own token from @BotFather. Skip these if you are only
# running the single orchestrator bot.
# BOT_NAME is set per-process by PM2 (ecosystem.config.cjs) — not needed here.
# ---------------------------------------------------------------------------
BOT_TOKEN_AI_JARVIS=your-orchestrator-bot-token-here
BOT_TOKEN_AI_TONY=your-engineer-specialist-bot-token-here
BOT_TOKEN_AI_NATASHA=your-research-specialist-bot-token-here
BOT_TOKEN_AI_BRUCE=your-analysis-specialist-bot-token-here
